# Review provider: "fixture" (offline, default) or "anthropic" (live Claude API)
# Use "fixture" for local development and CI — no API key required.
# Use "anthropic" in production or when testing the semantic analysis layer.
REVIEW_PROVIDER=fixture

# Required only when REVIEW_PROVIDER=anthropic.
# Obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Path to the SQLite database file. Defaults to ./greenlight.db in the project root.
# Override to point at a different location (e.g. a persistent volume in production).
# DB_PATH=./greenlight.db
